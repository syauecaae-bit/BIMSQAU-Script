local currentUniverseId = game.GameId -- Universe ID asli Roblox
print("Duality Hub: Mendeteksi Universe ID -> " .. tostring(currentUniverseId))

local GAMES_BY_UNIVERSE = {
    [7896876615] = "https://raw.githubusercontent.com/syauecaae-bit/BIMSQAU-Script/main/DoomByFate.lua",
    [9691752199] = "https://raw.githubusercontent.com/syauecaae-bit/BIMSQAU-Script/main/Sawah%20indo.lua",
    [9226697658] = "https://raw.githubusercontent.com/syauecaae-bit/BIMSQAU-Script/main/Shovel%20it!.lua",
    [7628235825] = "https://raw.githubusercontent.com/syauecaae-bit/BIMSQAU-Script/main/Simple%20spells.lua",
    [9753814298] = "https://raw.githubusercontent.com/syauecaae-bit/BIMSQAU-Script/main/Swingforbrainrot",
    [9695620503] = "https://raw.githubusercontent.com/syauecaae-bit/BIMSQAU-Script/refs/heads/main/Reel%20a%20brainrot",
}

local scriptUrl = GAMES_BY_UNIVERSE[currentUniverseId]

if scriptUrl then
    print("Game Terdeteksi! Memuat script...")
    -- Gunakan pcall agar jika script error, loader tidak berhenti total
    local success, err = pcall(function()
        loadstring(game:HttpGet(scriptUrl))()
    end)
    
    if not success then
        warn("Gagal memuat script: " .. tostring(err))
    end
else
    warn("Duality Hub: Game ini tidak terdaftar di database (ID: " .. tostring(currentUniverseId) .. ")")
end
